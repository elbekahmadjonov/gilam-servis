# Frontend build + Caddy bilan xizmat qilish (avto-HTTPS)
# ── 1-bosqich: Vite build (prod URL'lar build vaqtida "bake" qilinadi) ──
FROM node:22-alpine AS build
WORKDIR /app

# Backend domeni build vaqtida kerak (Vite env static bo'ladi)
ARG VITE_API_URL
ARG VITE_SOCKET_URL
ENV VITE_API_URL=$VITE_API_URL
ENV VITE_SOCKET_URL=$VITE_SOCKET_URL

COPY package.json ./
RUN npm install --no-audit --no-fund
COPY . .
RUN npm run build

# ── 2-bosqich: Caddy ─────────────────────────────────
FROM caddy:2-alpine
COPY Caddyfile /etc/caddy/Caddyfile
COPY --from=build /app/dist /srv
EXPOSE 80 443
