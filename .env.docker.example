# docker-compose (production) sozlamalari — nusxa oling:  cp .env.docker.example .env

# PostgreSQL
POSTGRES_USER=gilam
POSTGRES_PASSWORD=kuchli_parol_almashtiring
POSTGRES_DB=gilam

# JWT — MAJBURIY. Uzun tasodifiy qator:  openssl rand -hex 32
JWT_SECRET=
JWT_EXPIRES=30d

# CORS — web + admin domenlari (vergul bilan)
CORS_ORIGIN=https://gilam.qariya.uz,https://gilamadmin.qariya.uz

# Web client bazasi (bot menyu tugmasi URL'i)
WEB_BASE=https://gilam.qariya.uz

# initData yoshi (bot tokenlar endi har tenant'niki bazada — global BOT_TOKEN yo'q)
TELEGRAM_MAX_AGE_SEC=86400

# SuperAdmin (platforma egasi) — SUPER_PAROL MAJBURIY
SUPER_LOGIN=super
SUPER_PAROL=
SUPER_ISM=Super Admin

# Default tenant admini (orqaga moslik)
ADMIN_LOGIN=admin
ADMIN_PAROL=admin123

# Frontend build URL'lari
VITE_API_URL=https://gilamapi.qariya.uz/api
VITE_SOCKET_URL=https://gilamapi.qariya.uz
VITE_WEB_BASE=https://gilam.qariya.uz

# Let's Encrypt email (ixtiyoriy)
ACME_EMAIL=

# nginx/caddy tashqi porti — Caddy 80/443 ni oladi (WEB_PORT ishlatilmaydi)
