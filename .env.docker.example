# docker-compose (production) sozlamalari — nusxa oling:  cp .env.docker.example .env

# PostgreSQL
POSTGRES_USER=gilam
POSTGRES_PASSWORD=kuchli_parol_almashtiring
POSTGRES_DB=gilam

# JWT — MAJBURIY. Uzun tasodifiy qator:  openssl rand -hex 32
JWT_SECRET=
JWT_EXPIRES=30d

# CORS — web client domeni
CORS_ORIGIN=https://gilam.qariya.uz

# Telegram bot tokeni — MAJBURIY (initData tekshiruvi uchun)
BOT_TOKEN=
TELEGRAM_MAX_AGE_SEC=86400

# Frontend build uchun backend URL (domen o'zgarsa shu yerda o'zgartiring)
VITE_API_URL=https://gilamapi.qariya.uz/api
VITE_SOCKET_URL=https://gilamapi.qariya.uz

# Let's Encrypt uchun email (ixtiyoriy, lekin tavsiya etiladi)
ACME_EMAIL=

# Boshlang'ich admin (seed uchun)
ADMIN_LOGIN=admin
ADMIN_PAROL=admin123
