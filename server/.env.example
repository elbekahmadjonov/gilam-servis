# PostgreSQL ulanishi
DATABASE_URL=postgres://gilam:gilam_parol@localhost:5432/gilam

# JWT — ishlab chiqarishda albatta uzun tasodifiy qatorga almashtiring!
JWT_SECRET=almashtiring-uzun-tasodifiy-qator
JWT_EXPIRES=30d

# Server
PORT=3000
CORS_ORIGIN=*

# Web client bazasi (bot menyu tugmasi URL'i uchun)
WEB_BASE=https://gilam.qariya.uz

# Telegram Mini App — initData yoshi (bot tokenlar endi har tenant'niki bazada)
TELEGRAM_MAX_AGE_SEC=86400

# SuperAdmin (platforma egasi — npm run seed)
SUPER_LOGIN=super
SUPER_PAROL=super123
SUPER_ISM=Super Admin

# Default tenant admini (npm run seed — orqaga moslik uchun)
ADMIN_LOGIN=admin
ADMIN_PAROL=admin123
ADMIN_ISM=Administrator
